# ln -s ~/.dotfiles/git/.gitconfig ~/.gitconfig

[core]
	excludesfile = ~/.gitignore
	editor = cursor --wait
	ignorecase = false

[push]
	default = simple

[color]
	status = auto
	diff = auto
	branch = auto
	interactive = auto
	grep = auto
	ui = auto

